ARK_API_KEY=your_ark_api_key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Optional (v1.1.5): group-based key routing.
# Copy config/key_routing.json.example -> config/key_routing.json and set aliases.
# KEY_ROUTING_CONFIG_FILE=config/key_routing.json
# ARK_API_KEY_SEEDANCE_K1=your_seedance_key_k1
# ARK_API_KEY_SEEDANCE_K2=your_seedance_key_k2
# ARK_API_KEY_SEEDANCE_K3=your_seedance_key_k3

MATERIAL_PACK_TOS_ENABLED=true
TOS_ACCESS_KEY=your_tos_access_key
TOS_SECRET_KEY=your_tos_secret_key
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
TOS_BUCKET=your_bucket
TOS_PREFIX=material-packages-prod
TOS_PRESIGN_EXPIRES_SECONDS=3600

# Optional dedicated media-assets prefix.
# MEDIA_ASSET_TOS_PREFIX=media-assets-prod
